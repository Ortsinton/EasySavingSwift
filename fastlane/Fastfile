default_platform(:ios)

# Each plugin runs its binary from a different working directory
# (empirical finding, task 0-3): SwiftLint from the package dir,
# SwiftFormat from the invocation dir. Hence the two path sets.
SWIFTFORMAT_PATHS = "EasySaving EasySavingTests EasySavingUITests EasySavingKit/Sources EasySavingKit/Tests"
SWIFTLINT_PATHS = "../EasySaving ../EasySavingTests ../EasySavingUITests Sources Tests"
# Pinned snapshot environment (docs/TESTING.md): device name alone would let
# fastlane pick the highest runtime available on the machine; the explicit
# OS keeps CI (which ships several runtimes) on the reference environment.
DEVICE = "iPhone 17 (26.5)"
ROOT_PROJECT_SCHEME = "EasySaving"
ROOT_PROJECT_PATH = "EasySaving.xcodeproj"

platform :ios do
  desc "SwiftFormat (check mode) + SwiftLint (strict). Same command locally and in CI."
  lane :lint do
    Dir.chdir("..") do
      sh("swift package --package-path EasySavingKit plugin --allow-writing-to-package-directory swiftformat --lint --config .swiftformat --cache ignore #{SWIFTFORMAT_PATHS}")
      sh("swift package --package-path EasySavingKit plugin --allow-writing-to-package-directory swiftlint lint --strict --config ../.swiftlint.yml #{SWIFTLINT_PATHS}")
    end
  end

  desc "Build and run all tests: EasySavingKit via swift test, then the app scheme"
  lane :test do
    Dir.chdir("..") do
      sh("swift test --package-path EasySavingKit")
    end
    run_tests(
      project: ROOT_PROJECT_PATH,
      scheme: ROOT_PROJECT_SCHEME,
      device: DEVICE,
      parallel_testing: false,
      result_bundle: true
    )
  end

  desc "Snapshot tests only, on the pinned simulator (docs/TESTING.md)"
  lane :snap do
    run_tests(
      project: ROOT_PROJECT_PATH,
      scheme: ROOT_PROJECT_SCHEME,
      device: DEVICE,
      only_testing: ["EasySavingTests/ContentViewSnapshotTests"],
      parallel_testing: false,
      result_bundle: true
    )
  end
end
